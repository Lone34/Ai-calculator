# Frontend API config
# Local LAN (same Wi-Fi):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8000/api
#
# Production:
# EXPO_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api

EXPO_PUBLIC_API_BASE_URL=

# Optional fallback pieces if EXPO_PUBLIC_API_BASE_URL is blank
EXPO_PUBLIC_API_SCHEME=http
EXPO_PUBLIC_API_PORT=8000
EXPO_PUBLIC_API_HOST=
