# Django core
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true

# Local dev (can use *)
# Production: set real hosts, e.g. api.yourdomain.com
DJANGO_ALLOWED_HOSTS=*

# CORS / CSRF
# Local dev:
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# Production example:
# CORS_ALLOW_ALL_ORIGINS=false
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com

SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=false

# Gemini
GEMINI_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Subscription + trial
SUBSCRIPTION_ENFORCE_AI_SOLVE=true
SUBSCRIPTION_ENABLE_FREE_TRIAL=true
SUBSCRIPTION_FREE_TRIAL_DAYS=3
SUBSCRIPTION_TRIAL_TRUST_X_FORWARDED_FOR=false
SUBSCRIPTION_TRIAL_IP_HASH_SECRET=
